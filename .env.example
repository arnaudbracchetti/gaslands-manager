# ============================================================
# Template de configuration — Gaslands Manager
#
# Copier ce fichier en ".env" et remplir les valeurs réelles.
#   cp .env.example .env
#
# Ce fichier (.env.example) est commité sur GitHub.
# Le fichier .env ne l'est JAMAIS (voir .gitignore).
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
DB_USER=gaslands
DB_PASSWORD=change_me
DB_NAME=gaslands

# ── pgAdmin (interface web, http://localhost:5050) ───────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me
