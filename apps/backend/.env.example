# Copier ce fichier en .env et renseigner les valeurs
# cp .env.example .env  (Linux/Mac)
# Copy-Item .env.example .env  (Windows PowerShell)

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=gaslands

# Chemin relatif à la racine du workspace (process.cwd() lors d'un nx serve)
CONTENT_DIR=content

# Secret de signature des tokens JWT
JWT_SECRET=change_me

# Compte administrateur — créé/synchronisé automatiquement au démarrage par
# AdminSeedService. Un seul compte admin existe en base ; si ADMIN_PASSWORD
# change, son mot de passe est resynchronisé au prochain démarrage.
ADMIN_EMAIL=admin@gaslands.local
ADMIN_PASSWORD=change_me_in_env
